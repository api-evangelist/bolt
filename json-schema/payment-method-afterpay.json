{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://api.bolt.com/schemas/payment-method-afterpay",
  "title": "Afterpay Payment Method",
  "type": "object",
  "required": [
    ".tag",
    "return_url"
  ],
  "properties": {
    ".tag": {
      "type": "string",
      "enum": [
        "afterpay"
      ],
      "example": "afterpay"
    },
    "return_url": {
      "type": "string",
      "description": "Return URL to return to after payment completion in Afterpay.",
      "format": "url",
      "writeOnly": true,
      "example": "https://www.example.com/handle_afterpay_success"
    }
  }
}