{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://api.bolt.com/schemas/recognition-event-data",
  "title": "recognition-event-data",
  "type": "object",
  "required": [
    "email",
    "source",
    "confidence"
  ],
  "properties": {
    "email": {
      "type": "string",
      "description": "Email associated with user.",
      "example": "xyz@bolt.com"
    },
    "source": {
      "type": "string",
      "enum": [
        "unspecified",
        "login",
        "checkout",
        "merchant_api",
        "custom_rules"
      ],
      "description": "Source of recognition event",
      "example": "login"
    },
    "confidence": {
      "type": "string",
      "enum": [
        "unspecified",
        "unverified",
        "verified"
      ],
      "description": "Confidence level of recognition event",
      "example": "unverified"
    }
  }
}